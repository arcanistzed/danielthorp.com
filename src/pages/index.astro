		line-height: 1.6;
		max-width: 32rem;
	}

	.home :where(h2, h3) {
		letter-spacing: -0.015em;
		text-wrap: balance;
	}

	.home h2 {
		font-family: var(--font-display);
		font-size: 1.5rem;
		font-weight: 600;
		margin: 0;
	}

	.home section :where(p, ul, nav) {
		max-width: 65ch;
		margin: 0;
	}

	.home section :where(p, ul) + :where(p, ul) {
		margin-top: var(--space-3);
	}

	.home section p a {
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
	}

	:global(.js) .home :where(h1, h2, h3, p, li) {
		opacity: 0;
		transform: translateY(12px);
	}

	.socials {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
	}

	.socials a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: var(--radius-round);
		color: var(--color-text);
		text-decoration: none;
		background: var(--color-surface);
		transition: opacity var(--dur-2) var(--ease-out);
	}

	.socials a:hover {
