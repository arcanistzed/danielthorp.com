---
import BlueskyIcon from "../components/icons/BlueskyIcon.astro";
import DiscordIcon from "../components/icons/DiscordIcon.astro";
import EmailIcon from "../components/icons/EmailIcon.astro";
import GitHubIcon from "../components/icons/GitHubIcon.astro";
import InstagramIcon from "../components/icons/InstagramIcon.astro";
import LinkedInIcon from "../components/icons/LinkedInIcon.astro";
// import YouTubeIcon from "../components/icons/YouTubeIcon.astro";
import Layout from "../layouts/Layout.astro";

interface FeedItem {
	title: string;
	link: string;
	pubDate: string;
	description?: string;
}

let posts: FeedItem[] = [];
let fetchError = false;

function extractTag(xml: string, tag: string): string {
	const cdataPattern = new RegExp(
		`<${tag}>\\s*<!\\[CDATA\\[([\\s\\S]*?)\\]\\]>\\s*</${tag}>`,
	);
	const plainPattern = new RegExp(`<${tag}>([\\s\\S]*?)</${tag}>`);
	return cdataPattern.exec(xml)?.[1] ?? plainPattern.exec(xml)?.[1] ?? "";
}

try {
	const response = await fetch("https://arcanistzed.substack.com/feed", {
		signal: AbortSignal.timeout(5000),
	});
	if (!response.ok) throw new Error(`Feed returned ${response.status}`);
	const xml = await response.text();

	const items = xml.match(/<item>([\s\S]*?)<\/item>/g) || [];

	posts = items.slice(0, 5).map(item => {
		const title = extractTag(item, "title") || "Untitled";
		const link = extractTag(item, "link") || "#";
		const pubDate = extractTag(item, "pubDate");
		const description = extractTag(item, "description");

		return {
			title: decodeEntities(title.trim()),
			link: link.trim(),
			pubDate: pubDate.trim(),
			description,
		};
	});
} catch (e) {
	fetchError = true;
}

function formatDate(dateString: string): string {
	try {
		const date = new Date(dateString);
		return date.toLocaleDateString("en-US", {
			year: "numeric",
			month: "long",
			day: "numeric",
		});
	} catch {
		return "";
	}
}

function isoDate(dateString: string): string {
	try {
		return new Date(dateString).toISOString().split("T")[0];
	} catch {
		return dateString;
	}
}

function stripHtml(html: string): string {
	return html
		.replace(/<[^>]*>/g, "")
		.replace(/\s+/g, " ")
		.trim();
}

const NAMED_ENTITIES: Record<string, string> = {
	amp: "&",
	lt: "<",
	gt: ">",
	quot: '"',
	apos: "'",
	nbsp: "\u00A0",
	mdash: "\u2014",
	ndash: "\u2013",
	hellip: "\u2026",
	lsquo: "\u2018",
	rsquo: "\u2019",
	ldquo: "\u201C",
	rdquo: "\u201D",
	bull: "\u2022",
	middot: "\u00B7",
	copy: "\u00A9",
	reg: "\u00AE",
	trade: "\u2122",
	eacute: "\u00E9",
	egrave: "\u00E8",
	agrave: "\u00E0",
};

function decodeEntities(text: string): string {
	return text
		.replace(/&#x([0-9a-fA-F]+);/g, (_, hex) =>
			String.fromCharCode(Number.parseInt(hex, 16)),
		)
		.replace(/&#(\d+);/g, (_, num) =>
			String.fromCharCode(Number.parseInt(num, 10)),
		)
		.replace(
			/&([a-zA-Z]+);/g,
			(match, name) => NAMED_ENTITIES[name] ?? match,
		);
}

function excerpt(text?: string): string {
	if (!text) return "";
	const clean = decodeEntities(stripHtml(text));
	if (clean.length <= 180) return clean;
	const truncated = clean.slice(0, 180);
	const lastSpace = truncated.lastIndexOf(" ");
	return `${truncated.slice(0, lastSpace > 0 ? lastSpace : 180)}…`;
}
---

<Layout>
	<div class="home">
		<section aria-label="Header">
			<h1 class="name">Daniel Thorp</h1>
			<nav class="socials" aria-label="Socials">
				<a
					class="social-email"
					title="Email"
					href="mailto:daniel@danielthorp.com"
					aria-label="Send an email to Daniel Thorp"
				>
					<EmailIcon />
				</a>
				<a
					class="social-github"
					title="GitHub"
					href="https://github.com/arcanistzed"
					target="_blank"
					rel="noopener noreferrer me"
					aria-label="View Daniel Thorp's GitHub profile (opens in new tab)"
				>
					<GitHubIcon />
				</a>
				<a
					class="social-bluesky"
					title="Bluesky"
					href="https://bsky.app/profile/danielthorp.bsky.social"
					target="_blank"
					rel="noopener noreferrer me"
					aria-label="View Daniel Thorp's Bluesky profile (opens in new tab)"
				>
					<BlueskyIcon />
				</a>
				<a
					class="social-linkedin"
					title="LinkedIn"
					href="https://www.linkedin.com/in/daniel-a-thorp/"
					target="_blank"
					rel="noopener noreferrer me"
					aria-label="View Daniel Thorp's LinkedIn profile (opens in new tab)"
				>
					<LinkedInIcon />
				</a>
				<a
					class="social-discord"
					title="Discord"
					href="https://discord.com/users/455117777745870860"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="View Daniel Thorp's Discord profile (opens in new tab)"
				>
					<DiscordIcon />
				</a>
				<a
					class="social-instagram"
					title="Instagram"
					href="https://instagram.com/daniel.a.thorp"
					target="_blank"
					rel="noopener noreferrer me"
					aria-label="View Daniel Thorp's Instagram profile (opens in new tab)"
				>
					<InstagramIcon />
				</a>
				<!-- <a
				title="YouTube"
				href="https://youtube.com/@arcanistzed"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="View Daniel Thorp's YouTube channel (opens in new tab)"
			>
				<YouTubeIcon />
			</a> -->
			</nav>
		</section>

		<section aria-label="Introduction">
			<p>
				I’m a fourth-year Software Engineering student at the University
				of Ottawa.
			</p>
			<p>
				I’m drawn to the intersection of technology, law, and public
				policy, especially where better systems can produce better
				outcomes.
			</p>
			<p>
				This site brings together what I’m building, what I’m writing,
				and what I’m working on right now.
			</p>
		</section>

		<section aria-labelledby="focus">
			<h2 id="focus">Current areas of focus</h2>
			<ul class="focus" role="list">
				<li>
					Data privacy, artificial intelligence regulation,
					competition law, and digital policy.
				</li>
				<li>Writing, research, and public-interest advocacy.</li>
				<li>
					Leadership and governance through
					<a
						href="https://uodpa-apnuo.org/"
						target="_blank"
						rel="noopener noreferrer"
					>
						uODPA</a
					>
					and
					<a
						href="https://openmedia.org/"
						target="_blank"
						rel="noopener noreferrer"
					>
						OpenMedia</a
					>.
				</li>
				<li>
					Seeking opportunities in software engineering, DevOps, and
					digital policy.
				</li>
				<li>
					Building technical depth through my software engineering
					degree and personal projects.
				</li>
			</ul>
		</section>

		<section aria-labelledby="recent-writing">
			<h2 id="recent-writing">Recent writing</h2>
			{
				fetchError ? (
					<p>
						Writing is published on{" "}
						<a
							href="https://arcanistzed.substack.com"
							target="_blank"
							rel="noopener noreferrer"
						>
							Substack
						</a>
						.
					</p>
				) : posts.length === 0 ? (
					<p>
						No posts available. Visit{" "}
						<a
							href="https://arcanistzed.substack.com"
							target="_blank"
							rel="noopener noreferrer"
						>
							Substack
						</a>
						.
					</p>
				) : (
					<ul class="posts" role="list">
						{posts.map(post => (
							<li>
								<a
									href={post.link}
									target="_blank"
									rel="noopener noreferrer"
								>
									<h3>{post.title}</h3>
									{post.pubDate && (
										<time datetime={isoDate(post.pubDate)}>
											{formatDate(post.pubDate)}
										</time>
									)}
									{post.description && (
										<p>{excerpt(post.description)}</p>
									)}
								</a>
							</li>
						))}
					</ul>
				)
			}
		</section>
	</div>

	<script is:inline>
		const clearRevealStartStyles = el => {
			el.style.removeProperty("transform");
			el.style.removeProperty("opacity");
		};

		const clearRevealStyles = el => {
			clearRevealStartStyles(el);
			el.style.removeProperty("transition");
		};

		const revealItems = Array.from(
			document.querySelectorAll(
				".home :where(h1, h2, h3, p, a, time, li)",
			),
		);
		const prefersReducedMotion = window.matchMedia(
			"(prefers-reduced-motion: reduce)",
		).matches;

		if (revealItems.length && !prefersReducedMotion) {
			revealItems.forEach(el => {
				el.style.transform = "translateY(1rem)";
				el.style.opacity = 0;
			});

			let previousY = window.scrollY;
			const callback = entries => {
				const currentY = window.scrollY;
				entries.forEach(entry => {
					const { isIntersecting, target: el } = entry;
					if (!isIntersecting) {
						return;
					}
					const index = revealItems.indexOf(el);
					const delay = currentY === 0 ? Math.max(0, index) * 40 : 0;
					const shouldAnimate = currentY >= previousY;
					if (shouldAnimate) {
						el.style.transition = `transform 320ms ease ${delay}ms, opacity 320ms ease ${delay}ms`;
					}
					if (shouldAnimate) {
						const onRevealEnd = event => {
							if (event.propertyName !== "opacity") {
								return;
							}
							el.removeEventListener(
								"transitionend",
								onRevealEnd,
							);
							clearRevealStyles(el);
						};

						el.addEventListener("transitionend", onRevealEnd);
					}
					clearRevealStartStyles(el);
					if (!shouldAnimate) {
						clearRevealStyles(el);
					}
					observer.unobserve(el);
				});

				previousY = currentY;
			};

			const observer = new IntersectionObserver(callback, {
				root: null,
				rootMargin: "0px",
				threshold: 0,
			});

			revealItems.forEach(el => observer.observe(el));
		}
	</script>
</Layout>

<style>
	.home {
		max-width: 52rem;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: var(--space-7);
		font-size: 1.05rem;
		line-height: 1.8;
	}

	.home section {
		display: grid;
		gap: var(--space-4);
	}

	.name {
		font-family: var(--font-display);
		font-size: clamp(3rem, 7vw, 4.5rem);
		font-weight: 600;
		margin: 0 0 var(--space-3);
		line-height: 1.03;
		letter-spacing: -0.02em;
		text-align: center;
		white-space: nowrap;
	}

	@supports (background-clip: text) or (-webkit-background-clip: text) {
		.name {
			background: linear-gradient(
				110deg,
				var(--color-hero-start),
				var(--color-hero-mid),
				var(--color-hero-end)
			);
			background-size: 220% 220%;
			background-position: 20% 50%;
			-webkit-background-clip: text;
			background-clip: text;
			color: transparent;
			text-shadow: 0 1px 18px var(--color-hero-shadow);
			animation: hero-gradient-drift 24s ease-in-out infinite;
		}
	}

	@keyframes hero-gradient-drift {
		0% {
			background-position: 20% 50%;
		}
		50% {
			background-position: 80% 50%;
		}
		100% {
			background-position: 20% 50%;
		}
	}

	.posts time,
	.posts p {
		color: var(--color-muted);
		transition: color var(--dur-4);
	}

	.posts p {
		margin: 0 0 var(--space-2);
		line-height: 1.6;
		max-width: 32rem;
	}

	.home :where(h2, h3) {
		letter-spacing: -0.015em;
		text-wrap: balance;
	}

	.home h2 {
		font-family: var(--font-display);
		font-size: 1.5rem;
		font-weight: 600;
		margin: 0;
	}

	.home section :where(p, ul, nav) {
		max-width: 65ch;
		margin: 0;
	}

	.socials {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		align-items: center;
		gap: var(--space-6);
	}

	.socials a {
		--social-color: var(--color-muted);
		width: 2.5rem;
		color: var(--social-color);
		transition:
			color var(--dur-4),
			opacity var(--dur-4);
	}

	.socials a:hover {
		--social-color: color-mix(
			in srgb,
			var(--social-hover) 50%,
			var(--color-text)
		);
	}

	.socials a:focus-visible {
		--social-color: var(--social-hover);
	}

	.social-email {
		--social-hover: #d97a6a;
	}

	.social-github {
		--social-hover: #fff;
	}

	.social-bluesky {
		--social-hover: #0f73ff;
	}

	.social-linkedin {
		--social-hover: #0b66c3;
	}

	.social-discord {
		--social-hover: #5865f2;
	}

	.social-instagram {
		--social-hover: #c45d9b;
	}

	.socials svg {
		width: 1.25rem;
		height: 1.25rem;
	}

	.focus {
		padding-left: 1.25rem;
	}

	.focus li {
		margin: 0 0 var(--space-3);
		line-height: 1.6;
	}

	.posts {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		list-style: none;
		padding: 0;
	}

	.posts li {
		border: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
		border-radius: var(--radius-1);
		background: color-mix(in srgb, var(--color-surface) 80%, transparent);
		transition:
			background-color var(--dur-4),
			border-color var(--dur-4);
	}

	.posts a {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		padding: var(--space-4);
		text-decoration: none;
		transition: inherit;
	}

	.posts li:hover,
	.posts li:focus-within {
		background: color-mix(
			in srgb,
			var(--color-surface) 60%,
			var(--color-text) 5%
		);
		border-color: color-mix(in srgb, var(--color-text) 20%, transparent);
	}

	.posts li:hover p,
	.posts li:focus-within p,
	.posts li:hover time,
	.posts li:focus-within time {
		color: var(--color-text);
	}

	.posts h3 {
		color: var(--color-text);
		font-size: 1.1rem;
		margin: 0;
		text-decoration: underline;
		text-decoration-color: transparent;
		transition: color var(--dur-4);
	}

	.posts li:hover h3,
	.posts li:focus-within h3 {
		text-decoration-color: currentColor;
	}

	.posts time {
		display: block;
		font-size: 0.8rem;
	}

	@media (prefers-reduced-motion: reduce) {
		.home a,
		.posts a {
			transition: none;
		}
		.name {
			animation: none;
			filter: none;
		}
		.socials a {
			transition: none;
			animation: none;
			filter: none;
		}

		.posts li {
			transition: none;
		}
	}

	@media (max-width: 640px) {
		.name {
			font-size: 2.5rem;
			letter-spacing: 0;
		}

		.socials {
			gap: var(--space-2);
		}

		.socials a {
			width: 2rem;
			height: 2rem;
		}
	}
</style>
