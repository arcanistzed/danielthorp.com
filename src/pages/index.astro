---
import BlueskyIcon from "../components/icons/BlueskyIcon.astro";
import DiscordIcon from "../components/icons/DiscordIcon.astro";
import EmailIcon from "../components/icons/EmailIcon.astro";
import GitHubIcon from "../components/icons/GitHubIcon.astro";
import InstagramIcon from "../components/icons/InstagramIcon.astro";
import LinkedInIcon from "../components/icons/LinkedInIcon.astro";
import YouTubeIcon from "../components/icons/YouTubeIcon.astro";
import Layout from "../layouts/Layout.astro";

interface FeedItem {
	title: string;
	link: string;
	pubDate: string;
	description?: string;
}

let posts: FeedItem[] = [];
let fetchError = false;

function extractTag(xml: string, tag: string): string {
	const cdataPattern = new RegExp(
		`<${tag}>\\s*<!\\[CDATA\\[([\\s\\S]*?)\\]\\]>\\s*</${tag}>`,
	);
	const plainPattern = new RegExp(`<${tag}>([\\s\\S]*?)</${tag}>`);
	return cdataPattern.exec(xml)?.[1] ?? plainPattern.exec(xml)?.[1] ?? "";
}

try {
	const response = await fetch("https://arcanistzed.substack.com/feed", {
		signal: AbortSignal.timeout(5000),
	});
	if (!response.ok) throw new Error(`Feed returned ${response.status}`);
	const xml = await response.text();

	const items = xml.match(/<item>([\s\S]*?)<\/item>/g) || [];

	posts = items.slice(0, 5).map(item => {
		const title = extractTag(item, "title") || "Untitled";
		const link = extractTag(item, "link") || "#";
		const pubDate = extractTag(item, "pubDate");
		const description = extractTag(item, "description");

		return {
			title: decodeEntities(title.trim()),
			link: link.trim(),
			pubDate: pubDate.trim(),
			description,
		};
	});
} catch (e) {
	fetchError = true;
}

function formatDate(dateString: string): string {
	try {
		const date = new Date(dateString);
		return date.toLocaleDateString("en-US", {
			year: "numeric",
			month: "long",
			day: "numeric",
		});
	} catch {
		return "";
	}
}

function isoDate(dateString: string): string {
	try {
		return new Date(dateString).toISOString().split("T")[0];
	} catch {
		return dateString;
	}
}

function stripHtml(html: string): string {
	return html
		.replace(/<[^>]*>/g, "")
		.replace(/\s+/g, " ")
		.trim();
}

const NAMED_ENTITIES: Record<string, string> = {
	amp: "&",
	lt: "<",
	gt: ">",
	quot: '"',
	apos: "'",
	nbsp: "\u00A0",
	mdash: "\u2014",
	ndash: "\u2013",
	hellip: "\u2026",
	lsquo: "\u2018",
	rsquo: "\u2019",
	ldquo: "\u201C",
	rdquo: "\u201D",
	bull: "\u2022",
	middot: "\u00B7",
	copy: "\u00A9",
	reg: "\u00AE",
	trade: "\u2122",
	eacute: "\u00E9",
	egrave: "\u00E8",
	agrave: "\u00E0",
};

function decodeEntities(text: string): string {
	return text
		.replace(/&#x([0-9a-fA-F]+);/g, (_, hex) =>
			String.fromCharCode(Number.parseInt(hex, 16)),
		)
		.replace(/&#(\d+);/g, (_, num) =>
			String.fromCharCode(Number.parseInt(num, 10)),
		)
		.replace(
			/&([a-zA-Z]+);/g,
			(match, name) => NAMED_ENTITIES[name] ?? match,
		);
}

function excerpt(text?: string): string {
	if (!text) return "";
	const clean = decodeEntities(stripHtml(text));
	if (clean.length <= 180) return clean;
	const truncated = clean.slice(0, 180);
	const lastSpace = truncated.lastIndexOf(" ");
	return `${truncated.slice(0, lastSpace > 0 ? lastSpace : 180)}…`;
}
---

<Layout>
	<div class="home">
		<h1 class="name">Daniel Thorp</h1>
		<nav class="socials" aria-label="Socials">
			<a
				title="Email"
				href="mailto:daniel@danielthorp.com"
				aria-label="Send an email to Daniel Thorp"
			>
				<EmailIcon />
			</a>
			<a
				title="GitHub"
				href="https://github.com/arcanistzed"
				target="_blank"
				rel="noopener noreferrer me"
				aria-label="View Daniel Thorp's GitHub profile (opens in new tab)"
			>
				<GitHubIcon />
			</a>
			<a
				title="Bluesky"
				href="https://bsky.app/profile/danielthorp.bsky.social"
				target="_blank"
				rel="noopener noreferrer me"
				aria-label="View Daniel Thorp's Bluesky profile (opens in new tab)"
			>
				<BlueskyIcon />
			</a>
			<a
				title="LinkedIn"
				href="https://www.linkedin.com/in/daniel-a-thorp/"
				target="_blank"
				rel="noopener noreferrer me"
				aria-label="View Daniel Thorp's LinkedIn profile (opens in new tab)"
			>
				<LinkedInIcon />
			</a>
			<a
				title="Discord"
				href="https://discord.com/users/455117777745870860"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="View Daniel Thorp's Discord profile (opens in new tab)"
			>
				<DiscordIcon />
			</a>
			<a
				title="Instagram"
				href="https://instagram.com/daniel.a.thorp"
				target="_blank"
				rel="noopener noreferrer me"
				aria-label="View Daniel Thorp's Instagram profile (opens in new tab)"
			>
				<InstagramIcon />
			</a>
			<a
				title="YouTube"
				href="https://youtube.com/@arcanistzed"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="View Daniel Thorp's YouTube channel (opens in new tab)"
			>
				<YouTubeIcon />
			</a>
		</nav>

		<section aria-label="Introduction">
			<p>
				I’m a fourth-year Software Engineering student at the University
				of Ottawa.
			</p>
			<p>
				I’m drawn to the intersection of technology, law, and public
				policy, especially where better systems can produce better
				outcomes.
			</p>
			<p>
				This site brings together what I’m building, what I’m writing,
				and what I’m working on right now.
			</p>
		</section>

		<section aria-labelledby="focus">
			<h2 id="focus">Current areas of focus</h2>
			<ul class="focus" role="list">
				<li>
					Data privacy, artificial intelligence regulation,
					competition law, and digital policy.
				</li>
				<li>Writing, research, and public-interest advocacy.</li>
				<li>
					Leadership and governance through
					<a
						href="https://uodpa-apnuo.org/"
						target="_blank"
						rel="noopener noreferrer"
					>
						uODPA</a
					>
					and
					<a
						href="https://openmedia.org/"
						target="_blank"
						rel="noopener noreferrer"
					>
						OpenMedia</a
					>.
				</li>
				<li>
					Seeking opportunities in software engineering, DevOps, and
					digital policy.
				</li>
				<li>
					Building technical depth through my software engineering
					degree and personal projects.
				</li>
			</ul>
		</section>

		<section aria-labelledby="recent-writing">
			<h2 id="recent-writing">Recent writing</h2>
			{
				fetchError ? (
					<p>
						Writing is published on{" "}
						<a
							href="https://arcanistzed.substack.com"
							target="_blank"
							rel="noopener noreferrer"
						>
							Substack
						</a>
						.
					</p>
				) : posts.length === 0 ? (
					<p>
						No posts available. Visit{" "}
						<a
							href="https://arcanistzed.substack.com"
							target="_blank"
							rel="noopener noreferrer"
						>
							Substack
						</a>
						.
					</p>
				) : (
					<ul class="posts" role="list">
						{posts.map(post => (
							<li>
								<a
									href={post.link}
									target="_blank"
									rel="noopener noreferrer"
								>
									<h3>{post.title}</h3>
									{post.pubDate && (
										<time datetime={isoDate(post.pubDate)}>
											{formatDate(post.pubDate)}
										</time>
									)}
									{post.description && (
										<p>{excerpt(post.description)}</p>
									)}
								</a>
							</li>
						))}
					</ul>
				)
			}
		</section>
	</div>

	<script is:inline>
		const revealItems = Array.from(
			document.querySelectorAll(".home :where(h1, h2, h3, p, li)"),
		);
		const prefersReducedMotion = window.matchMedia(
			"(prefers-reduced-motion: reduce)",
		).matches;

		if (revealItems.length) {
			if (prefersReducedMotion) {
				revealItems.forEach(el => {
					el.style.transition = "none";
					el.style.transform = "none";
					el.style.opacity = 1;
				});
			} else {
				let previousY = window.scrollY;
				const callback = entries => {
					const currentY = window.scrollY;
					entries.forEach(entry => {
						const { isIntersecting, target: el } = entry;
						if (!isIntersecting) {
							return;
						}

						const index = revealItems.indexOf(el);
						const delay = Math.max(0, index) * 40;
						if (currentY >= previousY) {
							el.style.transition = "1s";
							el.style.transitionDelay = `${delay}ms`;
						} else {
							el.style.transition = "none";
							el.style.transitionDelay = "0ms";
						}
						el.style.transform = "none";
						el.style.opacity = 1;
						observer.unobserve(el);
					});

					previousY = currentY;
				};

				const observer = new IntersectionObserver(callback, {
					root: null,
					rootMargin: "0px",
					threshold: 0,
				});

				revealItems.forEach(el => observer.observe(el));
			}
		}
	</script>
</Layout>

<style>
	.home {
		max-width: 52rem;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		font-size: 1.05rem;
		line-height: 1.8;
	}

	.home section {
		display: grid;
		gap: var(--space-4);
		padding-top: var(--space-7);
	}

	.name {
		font-family: var(--font-display);
		font-size: clamp(3rem, 7vw, 4.5rem);
		font-weight: 600;
		margin: 0 0 var(--space-3);
		line-height: 1.03;
		letter-spacing: -0.02em;
		text-align: center;
		white-space: nowrap;
	}

	@supports (background-clip: text) or (-webkit-background-clip: text) {
		.name {
			background: linear-gradient(
				110deg,
				var(--color-hero-start),
				var(--color-hero-mid),
				var(--color-hero-end)
			);
			background-size: 220% 220%;
			background-position: 20% 50%;
			-webkit-background-clip: text;
			background-clip: text;
			color: transparent;
			text-shadow: 0 1px 18px var(--color-hero-shadow);
			animation: hero-gradient-drift 24s ease-in-out infinite;
		}
	}

	@keyframes hero-gradient-drift {
		0% {
			background-position: 20% 50%;
		}
		50% {
			background-position: 80% 50%;
		}
		100% {
			background-position: 20% 50%;
		}
	}

	.posts time,
	.posts p {
		color: var(--color-muted);
	}

	.posts p {
		margin: 0 0 var(--space-2);
		line-height: 1.6;
		max-width: 32rem;
	}

	.home :where(h2, h3) {
		letter-spacing: -0.015em;
		text-wrap: balance;
	}

	.home h2 {
		font-family: var(--font-display);
		font-size: 1.5rem;
		font-weight: 600;
		margin: 0;
	}

	.home section :where(p, ul, nav) {
		max-width: 65ch;
		margin: 0;
	}

	.home section :where(p, ul) + :where(p, ul) {
		margin-top: var(--space-3);
	}

	.home a {
		color: var(--color-text);
		transition:
			color var(--dur-2) var(--ease-out),
			text-decoration-color var(--dur-2) var(--ease-out),
			text-decoration-thickness var(--dur-2) var(--ease-out),
			background-color var(--dur-2) var(--ease-out),
			border-color var(--dur-2) var(--ease-out),
			box-shadow var(--dur-2) var(--ease-out),
			transform var(--dur-2) var(--ease-out);
	}

	.home section :is(p, li) a {
		text-decoration-line: underline;
		text-decoration-color: color-mix(
			in srgb,
			currentColor 42%,
			transparent
		);
		text-decoration-thickness: 1px;
		text-underline-offset: 0.16em;
	}

	.home section :is(p, li) a:hover {
		text-decoration-color: currentColor;
		text-decoration-thickness: 2px;
	}

	.home a:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 3px;
		text-decoration-color: currentColor;
	}

	:global(.js) .home :where(h1, h2, h3, p, li) {
		opacity: 0;
		transform: translateY(12px);
	}

	.socials {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: var(--space-4);
	}

	.socials a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: var(--radius-round);
		color: var(--color-text);
		text-decoration: none;
		border: 1px solid color-mix(in srgb, var(--color-text) 12%, transparent);
		background: var(--color-surface);
		box-shadow: 0 1px 0 rgba(255, 255, 255, 0.04) inset;
		text-decoration-thickness: 0;
		text-underline-offset: 0;
		transition:
			background-color var(--dur-2) var(--ease-out),
			border-color var(--dur-2) var(--ease-out),
			color var(--dur-2) var(--ease-out),
			box-shadow var(--dur-2) var(--ease-out),
			transform var(--dur-2) var(--ease-out);
	}

	.socials a:hover {
		background: color-mix(
			in srgb,
			var(--color-surface) 72%,
			var(--color-text) 8%
		);
		border-color: color-mix(in srgb, var(--color-text) 22%, transparent);
		transform: translateY(-1px);
	}

	.socials a:focus-visible {
		transform: translateY(-1px);
	}

	.socials svg {
		width: 1.25rem;
		height: 1.25rem;
	}

	.focus {
		margin: 0;
		padding-left: 1.25rem;
	}

	.focus li {
		margin: 0 0 var(--space-3);
		line-height: 1.6;
	}

	.focus li:last-child {
		margin-bottom: 0;
	}

	.posts {
		display: grid;
		gap: var(--space-3);
		list-style: none;
		padding: 0;
		margin: var(--space-4) 0 0;
	}

	.posts li {
		border: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
		border-radius: calc(var(--radius-1) + 0.25rem);
		background: color-mix(in srgb, var(--color-surface) 80%, transparent);
		box-shadow: 0 1px 0 rgba(255, 255, 255, 0.03) inset;
		transition:
			background-color var(--dur-2) var(--ease-out),
			border-color var(--dur-2) var(--ease-out),
			transform var(--dur-2) var(--ease-out),
			box-shadow var(--dur-2) var(--ease-out);
	}

	.posts a {
		display: block;
		padding: var(--space-4);
		text-decoration: none;
		transition: inherit;
	}

	.posts li:hover,
	.posts li:focus-within {
		background: color-mix(
			in srgb,
			var(--color-surface) 58%,
			var(--color-text) 4%
		);
		border-color: color-mix(in srgb, var(--color-text) 18%, transparent);
		transform: translateY(-1px);
		box-shadow: 0 14px 32px rgba(0, 0, 0, 0.12);
	}

	.posts a:hover {
		color: var(--color-text);
	}

	.posts h3 {
		font-size: 1.1rem;
		font-weight: 600;
		margin: 0 0 var(--space-2);
		color: var(--color-text);
		text-decoration-line: underline;
		text-decoration-color: transparent;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.2em;
		transition:
			text-decoration-color var(--dur-2) var(--ease-out),
			text-decoration-thickness var(--dur-2) var(--ease-out);
	}

	.posts li:hover h3,
	.posts li:focus-within h3 {
		text-decoration-color: color-mix(
			in srgb,
			currentColor 68%,
			transparent
		);
		text-decoration-thickness: 2px;
	}

	.posts time {
		display: block;
		font-size: 0.9rem;
		margin-bottom: var(--space-2);
	}

	.posts p {
		margin: 0;
		line-height: 1.6;
	}

	@media (prefers-reduced-motion: reduce) {
		.home a,
		.posts a {
			transition: none;
		}
		.name {
			animation: none;
			filter: none;
		}
		.socials a {
			transition: none;
		}

		.posts li {
			transition: none;
		}
	}

	@media (max-width: 640px) {
		.name {
			font-size: 11vw;
			letter-spacing: 0.01em;
		}

		.socials {
			gap: var(--space-2);
		}

		.socials a {
			width: 2.25rem;
			height: 2.25rem;
		}

		.socials svg {
			width: 1.1rem;
			height: 1.1rem;
		}

		.posts a {
			padding: var(--space-3);
		}
	}
</style>
