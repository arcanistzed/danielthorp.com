---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Daniel Thorp"
	description="Daniel Thorp — technology, governance, and systems."
>
	<div class="container">
		<header class="hero">
			<p class="eyebrow">Ottawa • Tech × Governance × Law</p>
			<h1>Daniel Thorp</h1>
			<p class="lede">
				I build systems, lead organizations, and work at the
				intersection of technology, governance, and public interest.
			</p>

			<div class="actions">
				<a class="button primary" href="/resume">Résumé</a>
				<a class="button" href="/writing">Writing</a>
				<a class="button" href="/about">About</a>
			</div>
		</header>

		<section class="section">
			<h2>Focus areas</h2>
			<ul class="focus">
				<li>
					Digital governance, accountability, and institutional design
				</li>
				<li>
					Technology policy: privacy, security, digital sovereignty
				</li>
				<li>
					Building tools and platforms for communities and
					organizations
				</li>
				<li>Nonprofit and student governance, bylaws, and process</li>
			</ul>
		</section>

		<section class="section">
			<h2>Selected work</h2>
			<div class="cards">
				<a
					class="card"
					href="https://hackthehill.com"
					target="_blank"
					rel="noreferrer"
				>
					<h3>Hack the Hill</h3>
					<p>
						Built and led systems for large-scale student
						hackathons.
					</p>
					<p class="meta">Leadership • Web • Operations</p>
				</a>

				<a
					class="card"
					href="https://tracker.hackthehill.com"
					target="_blank"
					rel="noreferrer"
				>
					<h3>Track the Hack</h3>
					<p>
						Event operations platform for verification, logistics,
						and workflow.
					</p>
					<p class="meta">Next.js • TypeScript • Systems</p>
				</a>

				<a class="card" href="/work">
					<h3>More projects</h3>
					<p>A curated archive of tools, sites, and experiments.</p>
					<p class="meta">Browse</p>
				</a>
			</div>
		</section>

		<section class="section">
			<h2>Find me</h2>
			<p class="muted">
				I write and publish updates on Substack, and I’m easiest to
				reach by email.
			</p>
			<div class="actions">
				<a class="button" href="mailto:you@domain.com">Email</a>
				<a
					class="button"
					href="https://www.linkedin.com/in/..."
					target="_blank"
					rel="noreferrer">LinkedIn</a
				>
				<a
					class="button"
					href="https://github.com/..."
					target="_blank"
					rel="noreferrer">GitHub</a
				>
				<a
					class="button"
					href="https://..."
					target="_blank"
					rel="noreferrer">Substack</a
				>
			</div>
		</section>

		<footer class="footer">
			<p class="muted">© {new Date().getFullYear()} Daniel Thorp</p>
		</footer>
	</div>
</Layout>

<style>
	.container {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: var(--space-8) var(--space-5);
	}

	.hero {
		padding: var(--space-8) 0 var(--space-6);
	}

	.eyebrow {
		font-family: var(--font-mono);
		color: var(--color-muted);
		margin: 0 0 var(--space-3);
	}

	h1 {
		font-size: clamp(2.4rem, 6vw, 4.5rem);
		line-height: 1.05;
		margin: 0 0 var(--space-4);
		letter-spacing: -0.02em;
	}

	.lede {
		font-size: 1.15rem;
		color: var(--color-muted);
		max-width: 60ch;
		margin: 0 0 var(--space-5);
	}

	.section {
		padding: var(--space-7) 0;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1rem;
		border-radius: var(--radius-2);
		border: 1px solid rgba(255, 255, 255, 0.14);
		text-decoration: none;
		color: var(--color-text);
		background: rgba(255, 255, 255, 0.03);
		transition:
			transform var(--dur-2) var(--ease-out),
			border-color var(--dur-2) var(--ease-out);
	}

	.button:hover {
		transform: translateY(-1px);
		border-color: rgba(255, 255, 255, 0.25);
	}

	.button.primary {
		border-color: color-mix(in srgb, var(--color-accent), white 15%);
	}

	.focus {
		margin: var(--space-4) 0 0;
		padding-left: 1.25rem;
		color: var(--color-muted);
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
		gap: var(--space-4);
		margin-top: var(--space-4);
	}

	.card {
		display: block;
		padding: var(--space-5);
		border-radius: var(--radius-2);
		border: 1px solid rgba(255, 255, 255, 0.12);
		text-decoration: none;
		color: inherit;
		background: rgba(255, 255, 255, 0.03);
		box-shadow: var(--shadow-1);
		transition:
			transform var(--dur-2) var(--ease-out),
			border-color var(--dur-2) var(--ease-out);
	}

	.card:hover {
		transform: translateY(-2px);
		border-color: rgba(255, 255, 255, 0.22);
	}

	.meta {
		margin-top: var(--space-3);
		font-family: var(--font-mono);
		font-size: 0.9rem;
		color: var(--color-muted);
	}

	.muted {
		color: var(--color-muted);
	}

	.footer {
		padding: var(--space-7) 0 var(--space-4);
	}

	@media (prefers-reduced-motion: reduce) {
		.button,
		.card {
			transition: none;
		}
		.button:hover,
		.card:hover {
			transform: none;
		}
	}
</style>
