---
import Footer from "../components/Footer.astro";
import "../styles/tokens.css";
import "../styles/base.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Daniel Thorp",
	description = "Daniel Thorp's personal website. Software engineering student at the University of Ottawa. Sharing thoughts on technology, public policy, and life.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://danielthorp.com");
const pageTitle = title === "Daniel Thorp" ? title : `${title} · Daniel Thorp`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="author" content="Daniel Thorp" />
		<meta name="generator" content={Astro.generator} />

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content="Daniel Thorp" />
		<meta
			property="og:image"
			content="https://danielthorp.com/og-image.png"
		/>
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta
			name="twitter:image"
			content="https://danielthorp.com/og-image.png"
		/>

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/manifest.json" />
		<link
			rel="alternate"
			type="application/rss+xml"
			title="Daniel Thorp"
			href="https://arcanistzed.substack.com/feed"
		/>

		<!-- Theme color -->
		<meta
			name="theme-color"
			content="#0a0b0d"
			media="(prefers-color-scheme: dark)"
		/>
		<meta
			name="theme-color"
			content="#ffffff"
			media="(prefers-color-scheme: light)"
		/>

		<!-- Structured data -->
		<script
			type="application/ld+json"
			set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": "WebSite",
				name: "Daniel Thorp",
				url: "https://danielthorp.com",
				author: {
					"@type": "Person",
					name: "Daniel Thorp",
					url: "https://danielthorp.com",
					email: "daniel@danielthorp.com",
					jobTitle: "Software Engineering Student",
					sameAs: [
						"https://github.com/arcanistzed",
						"https://www.linkedin.com/in/daniel-a-thorp/",
						"https://bsky.app/profile/danielthorp.bsky.social",
						"https://instagram.com/daniel.a.thorp",
						// "https://youtube.com/@arcanistzed",
					],
				},
			})}
		/>

		<title>{pageTitle}</title>

		<!-- Google Analytics -->
		<script
			async
			src="https://www.googletagmanager.com/gtag/js?id=G-PL71KBEP9H"
		></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag("js", new Date());
			gtag("config", "G-PL71KBEP9H");
		</script>

		<script is:inline>
			document.documentElement.classList.add("js");
		</script>
		<noscript>
			<style>
				.home :where(h1, h2, h3, p, li) {
					opacity: 1 !important;
					transform: none !important;
				}
			</style>
		</noscript>
	</head>

	<body>
		<div class="page-background" aria-hidden="true">
			<svg
				class="page-background-art page-background-art--dark"
				viewBox="0 0 1600 1200"
				preserveAspectRatio="xMidYMid slice"
				aria-hidden="true"
				role="img"
			>
				<defs>
					<linearGradient id="dark-base" x1="0%" y1="0%" x2="100%" y2="100%">
							<stop offset="0%" stop-color="var(--color-bg-art-dark-base-1)" />
							<stop offset="46%" stop-color="var(--color-bg-art-dark-base-2)" />
							<stop offset="100%" stop-color="var(--color-bg-art-dark-base-3)" />
					</linearGradient>

					<radialGradient id="dark-violetGlow" cx="50%" cy="50%" r="50%">
							<stop offset="0%" stop-color="var(--color-bg-art-dark-violet)" stop-opacity="0.42" />
							<stop offset="58%" stop-color="var(--color-bg-art-dark-violet)" stop-opacity="0.15" />
							<stop offset="100%" stop-color="var(--color-bg-art-dark-violet)" stop-opacity="0" />
					</radialGradient>

					<radialGradient id="dark-amberGlow" cx="50%" cy="50%" r="50%">
							<stop offset="0%" stop-color="var(--color-bg-art-dark-amber)" stop-opacity="0.30" />
							<stop offset="60%" stop-color="var(--color-bg-art-dark-amber)" stop-opacity="0.10" />
							<stop offset="100%" stop-color="var(--color-bg-art-dark-amber)" stop-opacity="0" />
					</radialGradient>

					<radialGradient id="dark-pinkGlow" cx="50%" cy="50%" r="50%">
							<stop offset="0%" stop-color="var(--color-bg-art-dark-pink)" stop-opacity="0.18" />
							<stop offset="62%" stop-color="var(--color-bg-art-dark-pink)" stop-opacity="0.06" />
							<stop offset="100%" stop-color="var(--color-bg-art-dark-pink)" stop-opacity="0" />
					</radialGradient>

					<radialGradient id="dark-edgeGlow" cx="50%" cy="50%" r="50%">
							<stop offset="0%" stop-color="var(--color-bg-art-dark-edge)" stop-opacity="0.12" />
							<stop offset="64%" stop-color="var(--color-bg-art-dark-edge)" stop-opacity="0.05" />
							<stop offset="100%" stop-color="var(--color-bg-art-dark-edge)" stop-opacity="0" />
					</radialGradient>
				</defs>

				<rect width="1600" height="1200" fill="url(#dark-base)" />

				<ellipse cx="260" cy="260" rx="460" ry="340" fill="url(#dark-violetGlow)" />
				<ellipse cx="1180" cy="340" rx="390" ry="300" fill="url(#dark-amberGlow)" />
				<ellipse cx="1020" cy="780" rx="470" ry="340" fill="url(#dark-pinkGlow)" />
				<ellipse cx="360" cy="720" rx="420" ry="300" fill="url(#dark-edgeGlow)" />
				<ellipse cx="-90" cy="860" rx="360" ry="250" fill="url(#dark-edgeGlow)" opacity="0.5" />
				<ellipse cx="540" cy="900" rx="330" ry="240" fill="url(#dark-violetGlow)" opacity="0.45" />
			</svg>

			<svg
				class="page-background-art page-background-art--light"
				viewBox="0 0 1600 1200"
				preserveAspectRatio="xMidYMid slice"
				aria-hidden="true"
				role="img"
			>
				<defs>
					<linearGradient id="light-base" x1="0%" y1="0%" x2="100%" y2="100%">
							<stop offset="0%" stop-color="var(--color-bg-art-light-base-1)" />
							<stop offset="48%" stop-color="var(--color-bg-art-light-base-2)" />
							<stop offset="100%" stop-color="var(--color-bg-art-light-base-3)" />
					</linearGradient>

					<radialGradient id="light-violetGlow" cx="50%" cy="50%" r="50%">
							<stop offset="0%" stop-color="var(--color-bg-art-light-violet)" stop-opacity="0.28" />
							<stop offset="60%" stop-color="var(--color-bg-art-light-violet)" stop-opacity="0.09" />
							<stop offset="100%" stop-color="var(--color-bg-art-light-violet)" stop-opacity="0" />
					</radialGradient>

					<radialGradient id="light-amberGlow" cx="50%" cy="50%" r="50%">
							<stop offset="0%" stop-color="var(--color-bg-art-light-amber)" stop-opacity="0.20" />
							<stop offset="62%" stop-color="var(--color-bg-art-light-amber)" stop-opacity="0.07" />
							<stop offset="100%" stop-color="var(--color-bg-art-light-amber)" stop-opacity="0" />
					</radialGradient>

					<radialGradient id="light-roseGlow" cx="50%" cy="50%" r="50%">
							<stop offset="0%" stop-color="var(--color-bg-art-light-rose)" stop-opacity="0.14" />
							<stop offset="64%" stop-color="var(--color-bg-art-light-rose)" stop-opacity="0.05" />
							<stop offset="100%" stop-color="var(--color-bg-art-light-rose)" stop-opacity="0" />
					</radialGradient>

					<radialGradient id="light-edgeGlow" cx="50%" cy="50%" r="50%">
							<stop offset="0%" stop-color="var(--color-bg-art-light-edge)" stop-opacity="0.10" />
							<stop offset="64%" stop-color="var(--color-bg-art-light-edge)" stop-opacity="0.04" />
							<stop offset="100%" stop-color="var(--color-bg-art-light-edge)" stop-opacity="0" />
					</radialGradient>
				</defs>

				<rect width="1600" height="1200" fill="url(#light-base)" />

				<ellipse cx="260" cy="260" rx="460" ry="340" fill="url(#light-violetGlow)" />
				<ellipse cx="1180" cy="340" rx="390" ry="300" fill="url(#light-amberGlow)" />
				<ellipse cx="1020" cy="780" rx="470" ry="340" fill="url(#light-roseGlow)" />
				<ellipse cx="360" cy="720" rx="420" ry="300" fill="url(#light-edgeGlow)" />
				<ellipse cx="-90" cy="860" rx="360" ry="250" fill="url(#light-edgeGlow)" opacity="0.46" />
				<ellipse cx="540" cy="900" rx="330" ry="240" fill="url(#light-violetGlow)" opacity="0.4" />
			</svg>
		</div>
		<a href="#content" class="skip-link">Skip to content</a>
		<main id="content">
			<slot />
		</main>

		<Footer />
	</body>
</html>
