---
import Footer from "../components/Footer.astro";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Daniel Thorp",
	description = "Fourth-year Software Engineering student. Law school next.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://danielthorp.com");
const pageTitle = title === "Daniel Thorp" ? title : `${title} · Daniel Thorp`;
const ogImage = new URL("/og-image.png", "https://danielthorp.com");
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="author" content="Daniel Thorp" />
		<meta name="theme-color" content="#0a0b0d" />
		<meta name="generator" content={Astro.generator} />

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:site_name" content="Daniel Thorp" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<title>{pageTitle}</title>

		<link rel="stylesheet" href="/styles/tokens.css" />
		<link rel="stylesheet" href="/styles/base.css" />
		<script is:inline>
			document.documentElement.classList.add("js");
		</script>
	</head>

	<body>
		<a href="#content" class="skip-link">Skip to content</a>
		<main id="content">
			<slot />
		</main>

		<Footer />
	</body>
</html>
